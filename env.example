# ============================================================
#  CodeOpt — Environment Variables
#  Copy this file to .env and fill in your values.
#  Never commit .env to version control.
# ============================================================

# ── MySQL ────────────────────────────────────────────────────
MYSQL_HOST=localhost
MYSQL_USER=root
MYSQL_PASS=root
MYSQL_DB=code_optimization_db

# ── MongoDB Atlas ─────────────────────────────────────────────
# Example: mongodb+srv://username:password@cluster0.abcde.mongodb.net/
MONGO_URI=YOUR_MONGODB_URI_HERE

# ── Neo4j ────────────────────────────────────────────────────
# Example (Aura): neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_URI=YOUR_NEO4J_URI_HERE
NEO4J_USER=neo4j
NEO4J_PASS=YOUR_NEO4J_PASSWORD_HERE

# ── Flask ────────────────────────────────────────────────────
FLASK_SECRET_KEY=replace-this-with-a-random-secret-key
FLASK_DEBUG=True

# ── Compiler Paths ───────────────────────────────────────────
# Windows (MSYS2 / MinGW)
# PYTHON_PATH=C:\Users\<you>\AppData\Local\Programs\Python\Python314\python.exe
# GCC_PATH=C:\msys64\ucrt64\bin\gcc.exe
# GPP_PATH=C:\msys64\ucrt64\bin\g++.exe

# Linux / macOS (use system paths)
# PYTHON_PATH=python3
# GCC_PATH=gcc
# GPP_PATH=g++
